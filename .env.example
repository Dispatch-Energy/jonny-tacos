# Teams Bot Configuration
TEAMS_APP_ID=your-teams-app-id-here
TEAMS_APP_SECRET=your-teams-app-secret-here
TEAMS_TENANT_ID=your-tenant-id-here

# QuickBase Configuration
QB_REALM=yourcompany.quickbase.com
QB_USER_TOKEN=your-quickbase-user-token
QB_APP_ID=your-quickbase-app-id
QB_APP_TOKEN=
QB_TICKETS_TABLE_ID=your-tickets-table-id
QB_WEBHOOK_SECRET=your-webhook-secret-here
QB_USER_CREATION_USER_TOKEN=
QB_USER_CREATION_APP_ID=btq7amgsn
QB_USER_CREATION_APP_TOKEN=
QB_USER_CREATION_ROLE_NAME=Participant

# AI Configuration (GPT-5)
GPT5_ENDPOINT=your-internal-gpt5-endpoint
GPT5_API_KEY=your-gpt5-api-key
GPT5_MODEL=gpt-5

# Azure OpenAI (Fallback)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-4

# LangChain / SharePoint Vector Store
LANGCHAIN_DB=postgresql://user:password@host:5432/dbname
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# IT Support Channel
IT_CHANNEL_ID=your-it-support-channel-id

# IT Automation - Admin Approval
# Email of the admin who approves automation requests (provisioning, etc.)
AUTOMATION_ADMIN_EMAIL=admin@yourcompany.com

# M365 Provisioning - Graph API Credentials
# Separate app registration for M365 resource provisioning (principle of least privilege)
# Required Graph API Application permissions: Group.ReadWrite.All, Directory.ReadWrite.All
M365_GRAPH_CLIENT_ID=your-graph-app-client-id
M365_GRAPH_CLIENT_SECRET=your-graph-app-client-secret
M365_GRAPH_TENANT_ID=your-tenant-id-or-leave-blank-to-use-TEAMS_TENANT_ID
M365_GRAPH_DOMAIN=yourcompany.com

# User Creation Automation
USER_CREATION_STANDARD_LICENSE_SKU=ENTERPRISEPACK
USER_CREATION_INTUNE_LICENSE_SKU=EMS
USER_CREATION_SHAREPOINT_GROUP_ID=your-sharepoint-access-group-id
USER_CREATION_EMAIL_SENDER=your.name@yourcompany.com
USER_CREATION_EMAIL_CC=
USER_CREATION_EMAIL_TIMEZONE=America/New_York
USER_CREATION_EMAIL_CONTAINER=scheduled-onboarding-emails
USER_CREATION_APPROVAL_CONTAINER=user-creation-approvals
USER_CREATION_USAGE_LOCATION=US
OPENAI_ADMIN_API_KEY=
OPENAI_USER_CREATION_ROLE=reader
OPENAI_USER_CREATION_PROJECTS=
ANTHROPIC_ADMIN_API_KEY=
ANTHROPIC_USER_CREATION_ROLE=user

# Application Insights (Optional)
APPLICATIONINSIGHTS_CONNECTION_STRING=your-connection-string
